# =============================================================
# Lobbix — environment configuration template
# Copy this file to .env and fill in real values for production
# =============================================================

# -------- Core server --------
NODE_ENV=development              # development | staging | production
PORT=3000
API_URL=http://localhost:3000     # production: https://lobbix.co.il
PUBLIC_URL=http://localhost:3000  # production: https://lobbix.co.il
SESSION_SECRET=change-this-to-64-random-hex-bytes  # openssl rand -hex 32

# -------- Demo / dev mode gate --------
# When DEMO_MODE=true:
#   - OTP code "123456" is accepted for ANY user (dev bypass)
#   - "Continue with Google (demo)" button is visible on login
#   - Seed test users are highlighted on the stage marketing panel
# Set to "false" before going to production.
DEMO_MODE=true

# -------- Database --------
# Local dev: uses SQLite at ./data/vaad.sqlite automatically (ignored if
# DATABASE_URL is not set or points to sqlite).
# Production: use a managed Postgres (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/lobbix_dev
# Optional — Redis for rate limit shared state + job queues (not required in MVP)
REDIS_URL=redis://localhost:6379

# -------- JWT / auth --------
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-64-random-hex-bytes
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=replace-with-a-different-64-random-hex-bytes
REFRESH_TOKEN_EXPIRES_IN=30d

# -------- Twilio (SMS for OTP) --------
# Register at https://twilio.com — A2P 10DLC registration required for Israel,
# takes 2-5 business days. Budget ~$0.08/SMS to +972.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+972xxxxxxxxx

# -------- SendGrid (transactional email) --------
# Free tier: 100 emails/day. Required for account verification + receipts.
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@lobbix.co.il
SENDGRID_FROM_NAME=Lobbix

# -------- Google OAuth --------
# https://console.cloud.google.com — create OAuth 2.0 Client ID
# Authorized origins: https://lobbix.co.il
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# -------- Firebase Cloud Messaging (push notifications) --------
# Required for real push when the app is wrapped in Capacitor/native.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key-here
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# -------- Israeli payment gateway --------
# Apply at https://tranzila.com (takes 1-2 weeks, requires ת.ז + bank details)
# Rates: ~2.5-3.5% + ₪0.70 per transaction.
TRANZILA_TERMINAL_ID=your-tranzila-terminal-id
TRANZILA_API_KEY=your-tranzila-api-key

# Alternative: Cardcom
# CARDCOM_TERMINAL=your-cardcom-terminal-id
# CARDCOM_API_USERNAME=your-cardcom-api-username

# Bit for business (optional, Israeli direct-to-phone payment)
# BIT_BUSINESS_API_KEY=your-bit-api-key
# BIT_MERCHANT_ID=your-bit-merchant-id

# -------- EZcount (Israeli tax receipts / חשבוניות and קבלות) --------
# For עוסק פטור: configure EZcount to issue קבלה only (no חשבונית מס).
# ~₪40/mo, https://ezcount.co.il
EZCOUNT_API_KEY=your-ezcount-api-key
EZCOUNT_DEVELOPER_EMAIL=liam@lobbix.co.il
# Identity: עוסק פטור. Do not charge VAT.
EZCOUNT_VAT_EXEMPT=true

# -------- Sentry (error monitoring) --------
# Free tier: 5k events/month. Sign up at https://sentry.io
SENTRY_DSN=https://xxxxx@xxxx.ingest.sentry.io/xxxxx

# -------- Optional: S3 / CDN for uploads --------
# Only needed if receipts/documents exceed a few hundred MB total.
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=lobbix-uploads
# AWS_REGION=eu-central-1
